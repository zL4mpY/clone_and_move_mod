{
	"geode": "5.5.3",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "loovigmd.clone_and_move",
	"name": "Clone and Move",
	"version": "v2.3.0",
	"developer": "enimeoww",
	"description": "Adds Copy + Paste + Move buttons.",
	"links": {
		"source": "https://github.com/zL4mpY/clone_and_move_mod"
	},
	"resources": {
		"spritesheets": {
			"CloneAndMoveButtons": [
				"res/CloneAndMoveButtons/*.png"
			]
		}
	},
	"dependencies": {
		"geode.node-ids": {
			"version": ">=v1.23.0",
			"required": true
		}
	},
	"settings": {
		"buttons-before-half-buttons": {
		    "type": "string",
		    "name": "Relocate buttons",
		    "description": "Relocates move buttons up to your wish. Note: relocating after move unit buttons will work only if BetterEdit is enabled.",
		    "default": "Default",
			"one-of": ["Before Half Move Buttons", "Default", "After Move Unit Buttons", "End"]
		},
		"move-step": {
		    "type": "float",
		    "name": "Move step",
		    "description": "Changes the move step for the buttons.",
		    "default": 1.0,
			"min": 0,
			"control": {
				"slider": true,
				"input": true,
				"arrows": true,
				"big-arrows": true,
				"slider-step": 0.5,
				"big-arrow-step": 0.5,
				"arrow-step": 0.25
			}
		},
		"clone-and-move-obj-up-keybind": {
			"type": "keybind",
			"name": "Clone and move object up",
			"category": "editor",
			"default": [],
			"migrate-from": "loovigmd.clone_and_move/clone-and-move-obj-up"
		},
		"clone-and-move-obj-down-keybind": {
			"type": "keybind",
			"name": "Clone and move object down",
			"category": "editor",
			"default": [],
			"migrate-from": "loovigmd.clone_and_move/clone-and-move-obj-down"
		},
		"clone-and-move-obj-left-keybind": {
			"type": "keybind",
			"name": "Clone and move object left",
			"category": "editor",
			"default": [],
			"migrate-from": "loovigmd.clone_and_move/clone-and-move-obj-left"
		},
		"clone-and-move-obj-right-keybind": {
			"type": "keybind",
			"name": "Clone and move object right",
			"category": "editor",
			"default": [],
			"migrate-from": "loovigmd.clone_and_move/clone-and-move-obj-right"
		}
	},
	"tags": [
		"editor", "enhancement", "offline"
	]
}
